{
    // set claude code to use plan mode by default
    "claudeCode.initialPermissionMode": "plan",
    // 
    "python.testing.pytestArgs": [
        "tests"
    ],
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,
    // format on save
    "editor.formatOnSave": true,
    // use "google" style for generating docstring with autoDocstring extension
    "autoDocstring.docstringFormat": "google",
    // Use project-specific virtual environment Python interpreter
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    // Automatically activate the virtual environment in the integrated terminal
    "python.terminal.activateEnvironment": true,
    "python-envs.defaultEnvManager": "ms-python.python:poetry",
    "python-envs.defaultPackageManager": "ms-python.python:poetry"
}