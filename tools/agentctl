#!/usr/bin/env python3
"""Minimal repo-local Mission Control CLI.

This intentionally uses only the Python standard library.
It is a small tool surface that Codex can call under the hood.
"""

from __future__ import annotations

import argparse
import contextlib
import datetime as _dt
import fcntl
import json
import pathlib
import shutil
import subprocess
import sys
import textwrap
import urllib.parse
from typing import Any


def repo_root() -> pathlib.Path:
    try:
        out = subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"], text=True
        ).strip()
        return pathlib.Path(out)
    except Exception:
        return pathlib.Path.cwd()


def load_json(path: pathlib.Path, default: Any) -> Any:
    if not path.exists():
        return default
    with path.open("r", encoding="utf-8") as f:
        return json.load(f)


def save_json(path: pathlib.Path, data: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    with tmp.open("w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, sort_keys=False)
        f.write("\n")
    tmp.replace(path)


def now_id() -> str:
    return _dt.datetime.now().strftime("R%Y%m%d-%H%M%S")


def md_table(headers: list[str], rows: list[list[Any]]) -> str:
    def cell(x: Any) -> str:
        return str(x) if x is not None else ""

    out = []
    out.append("| " + " | ".join(headers) + " |")
    out.append("|" + "|".join(["---" for _ in headers]) + "|")
    for row in rows:
        out.append("| " + " | ".join(cell(x).replace("\n", "<br>") for x in row) + " |")
    return "\n".join(out)


def status(root: pathlib.Path) -> dict[str, Any]:
    return load_json(root / ".agent" / "status.json", {})


def providers(root: pathlib.Path) -> dict[str, Any]:
    return load_json(root / ".agent" / "providers.json", {"providers": {}})


def usage(root: pathlib.Path) -> dict[str, Any]:
    return load_json(root / ".agent" / "usage.json", {"accounts": [], "sessions": []})


def project(root: pathlib.Path) -> dict[str, Any]:
    return load_json(root / ".agent" / "project.json", {})


def get_mission(st: dict[str, Any], mission_id: str) -> dict[str, Any] | None:
    for m in st.get("missions", []):
        if m.get("id") == mission_id:
            return m
    return None


def provider_rows(pconf: dict[str, Any]) -> list[list[Any]]:
    rows = []
    for pid, spec in pconf.get("providers", {}).items():
        rows.append(
            [
                pid,
                spec.get("kind"),
                spec.get("enabled", spec.get("kind") == "manual_main_session"),
                spec.get("aisw_context", ""),
                spec.get("aisw_profile", ""),
                spec.get("cost_class", ""),
                spec.get("description", ""),
            ]
        )
    return rows


def find_prefixed_file(directory: pathlib.Path, prefix: str) -> pathlib.Path | None:
    if not directory.exists():
        return None
    for p in sorted(directory.iterdir()):
        if p.is_file() and p.name.startswith(prefix):
            return p
    return None


class LaunchError(RuntimeError):
    """A launch precondition failed before a provider was started."""


def git_output(repository: pathlib.Path, *args: str) -> str:
    try:
        return subprocess.check_output(
            ["git", "-C", str(repository), *args],
            stderr=subprocess.STDOUT,
            text=True,
        ).strip()
    except subprocess.CalledProcessError as exc:
        detail = exc.output.strip()
        raise LaunchError(
            f"Git check failed for {repository}: {detail or ' '.join(args)}"
        ) from exc


def github_remote_identity(remote: str) -> str | None:
    value = remote.strip().rstrip("/")
    if value.startswith("git@github.com:"):
        path = value.removeprefix("git@github.com:")
    else:
        parsed = urllib.parse.urlparse(value)
        if (parsed.hostname or "").lower() != "github.com":
            return None
        path = parsed.path.lstrip("/")
    if path.endswith(".git"):
        path = path[:-4]
    parts = [part for part in path.split("/") if part]
    if len(parts) != 2:
        return None
    return f"github.com/{parts[0].lower()}/{parts[1].lower()}"


def normalized_lock(value: Any) -> tuple[str, tuple[str, ...]]:
    if not isinstance(value, str) or not value.strip():
        raise LaunchError("Path locks must be non-empty relative paths")
    path = pathlib.PurePosixPath(value)
    if path.is_absolute() or any(part in ("", ".", "..") for part in path.parts):
        raise LaunchError(f"Unsafe path lock: {value!r}")
    normalized = path.as_posix()
    return normalized, path.parts


def locks_overlap(left: tuple[str, ...], right: tuple[str, ...]) -> bool:
    common = min(len(left), len(right))
    return left[:common] == right[:common]


def mission_repository_keys(mission: dict[str, Any]) -> tuple[list[str], bool]:
    declared = mission.get("repositories")
    if declared is None:
        return ["mission-control"], True
    if not isinstance(declared, list) or not declared:
        raise LaunchError("Mission repositories must be a non-empty list")
    if any(not isinstance(key, str) or not key for key in declared):
        raise LaunchError("Mission repository keys must be non-empty strings")
    if len(set(declared)) != len(declared):
        raise LaunchError("Mission repository keys must be unique")
    return declared, False


def active_run_locks(root: pathlib.Path) -> list[tuple[str, str, tuple[str, ...]]]:
    active: list[tuple[str, str, tuple[str, ...]]] = []
    runs_dir = root / ".agent" / "runs"
    if not runs_dir.exists():
        return active
    for run_dir in sorted(runs_dir.iterdir()):
        meta = load_json(run_dir / "run.json", {})
        if meta.get("status") not in {"prepared", "manual_required", "running"}:
            continue
        for repository, values in meta.get("path_locks", {}).items():
            for value in values:
                normalized, parts = normalized_lock(value)
                active.append(
                    (repository, f"{meta.get('id', run_dir.name)}:{normalized}", parts)
                )
    return active


def validate_mission_targets(
    root: pathlib.Path,
    mission: dict[str, Any],
) -> tuple[list[dict[str, Any]], bool]:
    keys, legacy = mission_repository_keys(mission)
    registry = project(root).get("repositories", {})
    if legacy and "mission-control" not in registry:
        registry = {
            **registry,
            "mission-control": {
                "path": str(root),
                "expected_remote": git_output(root, "remote", "get-url", "origin"),
                "writable": True,
            },
        }
    requested_locks = mission.get("path_locks", {})
    if not isinstance(requested_locks, dict):
        raise LaunchError("Mission path_locks must be keyed by repository")
    unknown_lock_keys = sorted(set(requested_locks) - set(keys))
    if unknown_lock_keys:
        raise LaunchError(
            "Path locks target undeclared repositories: " + ", ".join(unknown_lock_keys)
        )

    active = active_run_locks(root)
    targets: list[dict[str, Any]] = []
    for key in keys:
        spec = registry.get(key)
        if not isinstance(spec, dict):
            raise LaunchError(f"Repository {key!r} is not registered")
        raw_path = spec.get("path")
        expected_remote = spec.get("expected_remote")
        writable = spec.get("writable")
        if not isinstance(raw_path, str) or not pathlib.Path(raw_path).is_absolute():
            raise LaunchError(
                f"Repository {key!r} must have an absolute registered path"
            )
        if not isinstance(expected_remote, str):
            raise LaunchError(f"Repository {key!r} has no expected GitHub remote")
        if not isinstance(writable, bool):
            raise LaunchError(f"Repository {key!r} has no boolean writable policy")

        source = pathlib.Path(raw_path)
        if not source.is_dir():
            raise LaunchError(f"Repository {key!r} does not exist: {source}")
        if git_output(source, "rev-parse", "--is-inside-work-tree") != "true":
            raise LaunchError(f"Repository {key!r} is not a Git worktree: {source}")
        top_level = pathlib.Path(git_output(source, "rev-parse", "--show-toplevel"))
        if top_level.resolve() != source.resolve():
            raise LaunchError(
                f"Repository {key!r} path is not its worktree root: {source}"
            )
        actual_remote = git_output(source, "remote", "get-url", "origin")
        actual_identity = github_remote_identity(actual_remote)
        expected_identity = github_remote_identity(expected_remote)
        if expected_identity is None:
            raise LaunchError(
                f"Repository {key!r} expected_remote is not a GitHub repository"
            )
        if actual_identity != expected_identity:
            raise LaunchError(
                f"Repository {key!r} remote mismatch: expected {expected_identity}, "
                f"found {actual_identity or actual_remote}"
            )
        agents_file = source / "AGENTS.md"
        if not agents_file.is_file():
            raise LaunchError(f"Repository {key!r} is missing AGENTS.md")
        if writable and git_output(source, "status", "--porcelain"):
            raise LaunchError(f"Writable repository {key!r} is dirty: {source}")

        raw_locks = requested_locks.get(key, [])
        if not isinstance(raw_locks, list):
            raise LaunchError(f"Path locks for {key!r} must be a list")
        locks: list[str] = []
        lock_parts: list[tuple[str, ...]] = []
        for value in raw_locks:
            normalized, parts = normalized_lock(value)
            if any(locks_overlap(parts, existing) for existing in lock_parts):
                raise LaunchError(
                    f"Mission has overlapping locks in {key!r}: {normalized}"
                )
            locks.append(normalized)
            lock_parts.append(parts)
        if not legacy and writable and not locks:
            raise LaunchError(
                f"Writable repository {key!r} requires at least one path lock"
            )
        if not writable and locks:
            raise LaunchError(f"Read-only repository {key!r} cannot receive path locks")
        for active_repository, active_label, active_parts in active:
            if active_repository != key:
                continue
            for lock, parts in zip(locks, lock_parts):
                if locks_overlap(parts, active_parts):
                    raise LaunchError(
                        f"Path lock conflict in {key!r}: {lock} overlaps {active_label}"
                    )

        targets.append(
            {
                "key": key,
                "source": source,
                "writable": writable,
                "expected_remote": expected_remote,
                "actual_remote": actual_remote,
                "baseline_head": git_output(source, "rev-parse", "HEAD"),
                "locks": locks,
                "agents_file": agents_file,
            }
        )
    return targets, legacy


@contextlib.contextmanager
def launch_lock(root: pathlib.Path) -> Any:
    runs_dir = root / ".agent" / "runs"
    runs_dir.mkdir(parents=True, exist_ok=True)
    with (runs_dir / ".launch.lock").open("a+", encoding="utf-8") as lock_file:
        fcntl.flock(lock_file.fileno(), fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(lock_file.fileno(), fcntl.LOCK_UN)


