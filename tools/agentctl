def cmd_mission(args: argparse.Namespace) -> int:
    root = repo_root()
    if args.mission_cmd == "list":
        st = status(root)
        print(
            md_table(
                ["Mission", "Title", "Stage", "State", "Agent", "Progress"],
                [
                    [
                        m.get("id"),
                        m.get("title"),
                        m.get("stage"),
                        m.get("state"),
                        m.get("agent"),
                        str(m.get("progress", 0)) + "%",
                    ]
                    for m in st.get("missions", [])
                ],
            )
        )
        return 0
    if args.mission_cmd == "show":
        path = find_prefixed_file(root / ".agent" / "missions", args.id)
        if not path:
            print(f"Mission file not found for {args.id}", file=sys.stderr)
            return 2
        print(path.read_text(encoding="utf-8"))
        return 0
    return 2


def cmd_task(args: argparse.Namespace) -> int:
    root = repo_root()
    if args.task_cmd == "list":
        task_dir = root / ".agent" / "tasks"
        rows = []
        for p in sorted(task_dir.glob("*.md")):
            rows.append([p.stem.split("-")[0] if "-" in p.stem else p.stem, p.name])
        print(md_table(["ID hint", "File"], rows))
        return 0
    if args.task_cmd == "show":
        path = find_prefixed_file(root / ".agent" / "tasks", args.id)
        if not path:
            print(f"Task file not found for {args.id}", file=sys.stderr)
            return 2
        print(path.read_text(encoding="utf-8"))
        return 0
    return 2


def mission_prompt(
    root: pathlib.Path,
    mission_id: str,
    targets: list[dict[str, Any]] | None = None,
) -> str:
    mission_file = find_prefixed_file(root / ".agent" / "missions", mission_id)
    if not mission_file:
        raise LaunchError(f"Mission file not found for {mission_id}")
    parts = []
    authority_files = [
        "AGENTS.md",
        "PROJECT_CHARTER.md",
        "ARCHITECTURE.md",
        "SPEC_INDEX.md",
    ]
    for rel in authority_files:
        p = root / rel
        if not p.is_file():
            raise LaunchError(f"Mission Control authority file is missing: {rel}")
        text = p.read_text(encoding="utf-8")
        parts.append(f"# File: {rel}\n\n{text}\n")
    parts.append(
        f"# Mission file: {mission_file.relative_to(root)}\n\n{mission_file.read_text(encoding='utf-8')}\n"
    )
    baseline = root / ".agent" / "S065_TECHNICAL_BASELINE.md"
    if not baseline.is_file():
        raise LaunchError("S065 implementation baseline is missing")
    parts.append(
        "# S065 implementation baseline: "
        f"{baseline.relative_to(root)}\n\n{baseline.read_text(encoding='utf-8')}\n"
    )
    if targets is not None:
        rows = []
        for target in targets:
            execution_path = target.get("worktree") or target["source"]
            if target["writable"] and target.get("worktree"):
                access = "writable isolated worktree"
            elif target["writable"]:
                access = "writable source (manual session)"
            else:
                access = "read-only evidence"
            rows.append(
                [
                    target["key"],
                    access,
                    execution_path,
                    target["baseline_head"],
                    ", ".join(target["locks"]) or "-",
                ]
            )
        parts.append(
            "# Repository execution map\n\n"
            + md_table(
                ["Repository", "Access", "Path", "Baseline HEAD", "Locks"],
                rows,
            )
            + "\n\n"
            + "For each writable repository that records lock roots, modify only files at or "
            + "below those roots; edits outside them are forbidden even though the surrounding "
            + "worktree is technically writable. A legacy writable repository with no recorded "
            + "locks may be modified within its isolated worktree, subject to its mission and "
            + "AGENTS.md. Read-only evidence paths must never receive edits, branches, or "
            + "worktrees.\n"
        )
        for target in targets:
            agents_file = target["agents_file"]
            parts.append(
                f"# Repository instructions: {target['key']} ({agents_file})\n\n"
                f"{agents_file.read_text(encoding='utf-8')}\n"
            )
    parts.append(
        textwrap.dedent(f"""
    # Execution instruction

    Execute mission {mission_id} exactly. Follow AGENTS.md.
    Commit coherent changes if the sandbox permits Git metadata writes. Otherwise leave the
    validated worktree changes unstaged for Mission Control to review and commit.
    Stop if a stop condition is reached.
    End with a final report.
    """)
    )
    return "\n\n".join(parts)


def add_isolated_worktrees(
    root: pathlib.Path,
    targets: list[dict[str, Any]],
    run_id: str,
    legacy: bool,
) -> tuple[pathlib.Path, pathlib.Path]:
    if legacy:
        workspace = root.parent / f"{root.name}-agent-worktrees"
        worktree_paths = [workspace / run_id]
    else:
        workspace = root.parent / f"{root.name}-agent-workspaces" / run_id
        worktree_paths = [
            workspace / target["key"] for target in targets if target["writable"]
        ]
    if legacy:
        workspace.mkdir(parents=True, exist_ok=True)
    else:
        workspace.parent.mkdir(parents=True, exist_ok=True)
        try:
            workspace.mkdir()
        except FileExistsError as exc:
            raise LaunchError(f"Run workspace already exists: {workspace}") from exc
    if not legacy:
        subprocess.check_call(
            ["git", "init", "-q", str(workspace)],
            stdout=subprocess.DEVNULL,
        )

    created: list[dict[str, Any]] = []
    try:
        writable_index = 0
        for target in targets:
            target["worktree"] = None
            target["branch"] = None
            if not target["writable"]:
                continue
            worktree = worktree_paths[writable_index]
            writable_index += 1
            branch = f"agent/{run_id}"
            if worktree.exists():
                raise LaunchError(f"Run worktree already exists: {worktree}")
            target["worktree"] = worktree
            target["branch"] = branch
            created.append(target)
            subprocess.check_call(
                [
                    "git",
                    "-C",
                    str(target["source"]),
                    "worktree",
                    "add",
                    "-b",
                    branch,
                    str(worktree),
                    target["baseline_head"],
                ]
            )
    except Exception as exc:
        cleanup_errors = cleanup_worktrees(created)
        if not legacy:
            try:
                shutil.rmtree(workspace)
            except FileNotFoundError:
                pass
            except OSError as cleanup_exc:
                cleanup_errors.append(
                    f"could not remove coordination workspace {workspace}: {cleanup_exc}"
                )
        if cleanup_errors:
            raise LaunchError(
                f"Worktree preparation failed: {exc}. Cleanup was incomplete; "
                "manual recovery is required: " + "; ".join(cleanup_errors)
            ) from exc
        raise

    if legacy:
        provider_cwd = pathlib.Path(targets[0]["worktree"])
        return provider_cwd, provider_cwd
    return workspace, workspace


def cleanup_worktrees(targets: list[dict[str, Any]]) -> list[str]:
    errors: list[str] = []
    for target in reversed(targets):
        worktree = target.get("worktree")
        branch = target.get("branch")
        if worktree is not None:
            result = subprocess.run(
                [
                    "git",
                    "-C",
                    str(target["source"]),
                    "worktree",
                    "remove",
                    "--force",
                    str(worktree),
                ],
                check=False,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
            )
            if result.returncode != 0 and pathlib.Path(worktree).exists():
                errors.append(
                    f"could not remove worktree {worktree}: {result.stdout.strip()}"
                )
        if branch is not None:
            result = subprocess.run(
                ["git", "-C", str(target["source"]), "branch", "-D", str(branch)],
                check=False,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
            )
            if result.returncode != 0:
                remaining = git_output(
                    pathlib.Path(target["source"]), "branch", "--list", str(branch)
                )
                if remaining:
                    errors.append(
                        f"could not remove branch {branch} in {target['source']}: "
                        f"{result.stdout.strip()}"
                    )
    return errors


def run_repository_metadata(targets: list[dict[str, Any]]) -> list[dict[str, Any]]:
    return [
        {
            "key": target["key"],
            "source": str(target["source"]),
            "writable": target["writable"],
            "baseline_head": target["baseline_head"],
            "worktree": str(target["worktree"]) if target.get("worktree") else None,
            "branch": target.get("branch"),
            "locks": target["locks"],
        }
        for target in targets
    ]


def cmd_launch(args: argparse.Namespace) -> int:
    root = repo_root()
    st = status(root)
    pconf = providers(root).get("providers", {})
    mids: list[str] = []
    if args.approved:
        mids = [
            str(m.get("id"))
            for m in st.get("missions", [])
            if m.get("state") == "approved"
        ]
    else:
        mids = [args.id]
    if not mids:
        print("No approved missions to launch.")
        return 0
    result = 0
    for mid in mids:
        m = get_mission(st, mid)
        if not m:
            print(f"Mission {mid} not found", file=sys.stderr)
            result = 2
            continue
        if m.get("state") != "approved":
            print(f"Mission {mid} is not approved", file=sys.stderr)
            result = 2
            continue
        provider_id = args.provider or m.get("agent") or "local-main-codex"
        provider = pconf.get(provider_id)
        if not provider:
            print(f"Provider {provider_id} not found for {mid}", file=sys.stderr)
            result = 2
            continue
        cmd_template = provider.get("command_template")
        manual = provider.get("kind") == "manual_main_session" or not provider.get(
            "enabled", False
        )
        if not manual and not cmd_template:
            print(f"Provider {provider_id} has no command_template", file=sys.stderr)
            result = 2
            continue
        mission_file = find_prefixed_file(root / ".agent" / "missions", mid)
        if not mission_file or "## Stop conditions" not in mission_file.read_text(
            encoding="utf-8"
        ):
            print(f"Mission {mid} has no declared stop conditions", file=sys.stderr)
            result = 2
            continue

        with launch_lock(root):
            targets: list[dict[str, Any]] = []
            worktrees_created = False
            provider_started = False
            legacy = True
            run_id = now_id() + "-" + mid
            run_dir = root / ".agent" / "runs" / run_id
            try:
                locked_status = status(root)
                locked_mission = get_mission(locked_status, mid)
                if not locked_mission or locked_mission.get("state") != "approved":
                    raise LaunchError(
                        f"Mission {mid} is no longer approved after launch serialization"
                    )
                st = locked_status
                m = locked_mission
                targets, legacy = validate_mission_targets(root, m)
                for target in targets:
                    target["worktree"] = None
                    target["branch"] = None
                provider_cwd = root
                workspace: pathlib.Path | None = None
                if not manual:
                    workspace, provider_cwd = add_isolated_worktrees(
                        root, targets, run_id, legacy
                    )
                    worktrees_created = True

                run_dir.mkdir(parents=True, exist_ok=False)
                prompt_file = run_dir / "prompt.md"
                prompt_file.write_text(
                    mission_prompt(root, mid, targets), encoding="utf-8"
                )
                run_meta = {
                    "id": run_id,
                    "mission": mid,
                    "provider": provider_id,
                    "status": "prepared",
                    "created_at": _dt.datetime.now().isoformat(),
                    "prompt_file": str(prompt_file),
                    "workspace": str(workspace) if workspace else None,
                    "repositories": run_repository_metadata(targets),
                    "path_locks": {
                        target["key"]: target["locks"]
                        for target in targets
                        if target["locks"]
                    },
                    "pid": None,
                    "command": None,
                }
                writable_targets = [target for target in targets if target["writable"]]
                if len(writable_targets) == 1 and writable_targets[0].get("worktree"):
                    run_meta["worktree"] = str(writable_targets[0]["worktree"])
                    run_meta["branch"] = writable_targets[0]["branch"]

                launcher_log = run_dir / "launcher.log"
                if manual:
                    run_meta["status"] = "manual_required"
                    launcher_log.write_text(
                        "Prepared for manual/current-session execution; no provider started.\n",
                        encoding="utf-8",
                    )
                    save_json(run_dir / "run.json", run_meta)
                    print(
                        f"# Mission {mid} prepared for manual/current-session execution\n"
                    )
                    print(f"Prompt file: `{prompt_file}`\n")
                    print(
                        "Provider is manual or disabled. The current Mission Control "
                        "agent should execute this mission directly, or configure providers first."
                    )
                    continue

                try:
                    cmd = str(cmd_template).format(
                        aisw_context=provider.get("aisw_context", ""),
                        prompt_file=str(prompt_file),
                        run_dir=str(run_dir),
                        worktree=str(provider_cwd),
                        workspace=str(workspace),
                        mission_id=mid,
                        run_id=run_id,
                    )
                except (KeyError, IndexError, ValueError) as exc:
                    raise LaunchError(
                        f"Provider {provider_id} command template is invalid: {exc}"
                    ) from exc
                run_meta["command"] = cmd
                if args.prepare_only:
                    launcher_log.write_text(
                        "Preparation-only run; provider command was not started.\n",
                        encoding="utf-8",
                    )
                    save_json(run_dir / "run.json", run_meta)
                    print(f"Prepared {mid} as {run_id}; provider was not launched.")
                    continue

                run_meta["status"] = "running"
                save_json(run_dir / "run.json", run_meta)
                with launcher_log.open("w", encoding="utf-8") as log:
                    proc = subprocess.Popen(
                        cmd,
                        cwd=root,
                        shell=True,
                        stdout=log,
                        stderr=subprocess.STDOUT,
                        start_new_session=True,
                    )
                provider_started = True
                run_meta["pid"] = proc.pid
                save_json(run_dir / "run.json", run_meta)
                m["state"] = "running"
                m["agent"] = provider_id
                save_json(root / ".agent" / "status.json", st)
                print(f"Launched {mid} as {run_id} with provider {provider_id}.")
            except (LaunchError, OSError, subprocess.SubprocessError) as exc:
                cleanup_errors: list[str] = []
                if worktrees_created and not provider_started:
                    cleanup_errors.extend(cleanup_worktrees(targets))
                    if workspace is not None and not legacy:
                        try:
                            shutil.rmtree(workspace)
                        except FileNotFoundError:
                            pass
                        except OSError as cleanup_exc:
                            cleanup_errors.append(
                                f"could not remove coordination workspace {workspace}: "
                                f"{cleanup_exc}"
                            )
                if cleanup_errors:
                    exc = LaunchError(
                        f"{exc}. Cleanup was incomplete; manual recovery is required: "
                        + "; ".join(cleanup_errors)
                    )
                if run_dir.exists() and not provider_started:
                    save_json(
                        run_dir / "run.json",
                        {
                            "id": run_id,
                            "mission": mid,
                            "provider": provider_id,
                            "status": "failed",
                            "created_at": _dt.datetime.now().isoformat(),
                            "error": str(exc),
                            "pid": None,
                            "command": None,
                        },
                    )
                action = (
                    "Provider started but final metadata update failed"
                    if provider_started
                    else "Launch refused"
                )
                print(f"{action} for {mid}: {exc}", file=sys.stderr)
                result = 2
    return result


def cmd_runs(args: argparse.Namespace) -> int:
    root = repo_root()
    run_dir = root / ".agent" / "runs"
    rows = []
    totals: dict[str, int] = {}
    if run_dir.exists():
        for p in sorted(run_dir.iterdir(), reverse=True):
            meta = load_json(p / "run.json", {})
            if meta:
                state = meta.get("status", "unknown")
                totals[state] = totals.get(state, 0) + 1
                rows.append(
                    [
                        meta.get("id"),
                        meta.get("mission"),
                        meta.get("provider"),
                        state,
                        meta.get("pid", ""),
                        meta.get("created_at", ""),
                    ]
                )
    print("# Runs\n")
    if rows:
        print(
            md_table(["Run", "Mission", "Provider", "Status", "PID", "Created"], rows)
        )
        print()
        print(
            md_table(["Status", "Count"], [[k, v] for k, v in sorted(totals.items())])
        )
    else:
        print("No runs found.")
        print("\nRun metadata should be stored as `.agent/runs/<RUN_ID>/run.json`.")
    return 0


def cmd_pro_packet(args: argparse.Namespace) -> int:
    root = repo_root()
    cdir = root / ".agent" / "consultations"
    print("# ChatGPT Pro consultation packets\n")
    files = sorted(cdir.glob("P*.md")) if cdir.exists() else []
    if not files:
        print("No consultation packets found.")
        return 0
    for p in files:
        print(f"- `{p.relative_to(root)}`")
    if args.id:
        path = find_prefixed_file(cdir, args.id)
        if path:
            print("\n---\n")
            print(path.read_text(encoding="utf-8"))
    return 0


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(prog="agentctl")
    sub = parser.add_subparsers(dest="cmd", required=True)
    sub.add_parser("brief").set_defaults(func=cmd_brief)
    sub.add_parser("review-now").set_defaults(func=cmd_review_now)
    sub.add_parser("next").set_defaults(func=cmd_next)
    sub.add_parser("usage").set_defaults(func=cmd_usage)
    sub.add_parser("runs").set_defaults(func=cmd_runs)

    p_m = sub.add_parser("mission")
    msub = p_m.add_subparsers(dest="mission_cmd", required=True)
    msub.add_parser("list")
    p_show = msub.add_parser("show")
    p_show.add_argument("id")
    p_m.set_defaults(func=cmd_mission)

    p_t = sub.add_parser("task")
    tsub = p_t.add_subparsers(dest="task_cmd", required=True)
    tsub.add_parser("list")
    t_show = tsub.add_parser("show")
    t_show.add_argument("id")
    p_t.set_defaults(func=cmd_task)

    p_launch = sub.add_parser("launch")
    p_launch.add_argument("id")
    p_launch.add_argument("--provider", default=None)
    p_launch.add_argument("--prepare-only", action="store_true")
    p_launch.set_defaults(func=cmd_launch, approved=False)

    p_la = sub.add_parser("launch-approved")
    p_la.add_argument("--provider", default=None)
    p_la.add_argument("--prepare-only", action="store_true")
    p_la.set_defaults(func=cmd_launch, approved=True, id=None)

    p_pro = sub.add_parser("pro-packet")
    p_pro.add_argument("id", nargs="?", default=None)
    p_pro.set_defaults(func=cmd_pro_packet)

    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
