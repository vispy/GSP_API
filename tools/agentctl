def cmd_review_now(args: argparse.Namespace) -> int:
    root = repo_root()
    st = status(root)
    print("# Review queue\n")
    reviews = st.get("review_queue", [])
    questions = [q for q in st.get("open_questions", []) if q.get("state") == "open"]
    needs = []
    for r in reviews:
        needs.append(
            [r.get("id"), "review", r.get("summary", ""), r.get("priority", "")]
        )
    for q in questions:
        needs.append(
            [
                q.get("id"),
                "question",
                q.get("summary", ""),
                "human" if q.get("requires_human") else "",
            ]
        )
    ready = [
        m for m in st.get("missions", []) if m.get("state") in ("approved", "ready")
    ]
    approved = [m for m in ready if m.get("state") == "approved"]
    for m in ready:
        needs.append([m.get("id"), "mission", m.get("title", ""), m.get("state")])
    blocked = [m for m in st.get("missions", []) if m.get("state") == "blocked"]
    for m in blocked:
        needs.append([m.get("id"), "blocked", m.get("title", ""), m.get("agent", "")])
    if not needs:
        print("No review items found.")
    else:
        print(md_table(["ID", "Type", "Summary", "Priority/State"], needs))
    print("\n## Suggested action\n")
    if questions:
        print(
            "Resolve open human questions before launching dependent external workers."
        )
    elif blocked:
        print(
            "Review blocked missions and either resolve blockers or create a consultation packet."
        )
    elif approved:
        print("Use `tools/agentctl launch-approved` when the user says 'do it'.")
    elif ready:
        print(
            "Ask Mission Control to approve the ready mission, or execute it directly in the current session when appropriate."
        )
    else:
        print("Ask Mission Control to propose or refine the next mission.")
    return 0


def cmd_next(args: argparse.Namespace) -> int:
    root = repo_root()
    st = status(root)
    missions = sorted(st.get("missions", []), key=lambda m: m.get("priority", 999))
    rows = []
    for m in missions:
        if m.get("state") in ("draft", "ready", "approved", "blocked"):
            rows.append(
                [
                    m.get("id"),
                    m.get("title"),
                    m.get("state"),
                    m.get("stage"),
                    m.get("priority"),
                ]
            )
    print("# Recommended next missions\n")
    if rows:
        print(md_table(["Mission", "Title", "State", "Stage", "Priority"], rows))
        ready = [row for row in rows if row[2] == "ready"]
        if ready:
            print(f"\nSuggested next mission: `{ready[0][0]}`.")
    else:
        print("No next missions listed.")
    return 0


